<div class="page-header">
  <div>
    <h1 class="page-title">
      <% if params[:query].present? %>
        Search Results for "<%= params[:query] %>"
      <% else %>
        Editorial Perspectives
      <% end %>
    </h1>
    <p class="page-subtitle">Curated essays, reflections, and deep dives on design, architecture, and technology.</p>
  </div>
  <div>
    <%= link_to "+ Write Article", new_article_path, class: "btn btn-primary" %>
  </div>
</div>

<% if @articles.empty? %>
  <div style="text-align: center; padding: 5rem 2rem; background: var(--bg-card); border-radius: var(--radius-lg); border: 1px solid var(--border-color);">
    <h3 style="font-family: var(--font-serif); margin-bottom: 1rem; color: var(--text-primary);">No articles found</h3>
    <p style="color: var(--text-muted); margin-bottom: 2rem;">We couldn't find any articles matching your query or filter.</p>
    <%= link_to "View All Articles", articles_path, class: "btn btn-secondary" %>
  </div>
<% else %>
  <div class="articles-grid">
    <% @articles.each do |article| %>
      <article class="article-card">
        <% if article.image_exists? %>
          <div class="article-image-wrapper">
            <%= link_to article_path(article) do %>
              <%= image_tag article.image_url, class: "article-image", alt: article.title %>
            <% end %>
          </div>
        <% else %>
          <div class="article-image-wrapper" style="background: linear-gradient(135deg, #f5f2eb 0%, #e8e4dc 100%); display: flex; align-items: center; justify-content: center;">
            <span style="font-family: var(--font-serif); color: var(--text-muted); font-size: 1.25rem; font-weight: 700;">Blogger.</span>
          </div>
        <% end %>

        <div class="article-card-content">
          <div class="article-meta">
            <span><%= article.created_at.strftime("%B %d, %Y") %></span>
            <span>&bull;</span>
            <span class="read-time"><%= article.reading_time %> min read</span>
          </div>

          <h2 class="article-card-title">
            <%= link_to article.title, article_path(article) %>
          </h2>

          <p class="article-excerpt">
            <%= truncate(article.body, length: 140) %>
          </p>

          <div class="article-footer">
            <div style="display: flex; gap: 0.4rem; flex-wrap: wrap;">
              <% article.tags.first(3).each do |tag| %>
                <%= link_to tag.name, tag_path(tag), class: "tag-badge" %>
              <% end %>
            </div>
            <div>
              <%= link_to "Read &rarr;".html_safe, article_path(article), style: "font-weight: 600; font-size: 0.85rem;" %>
            </div>
          </div>
        </div>
      </article>
    <% end %>
  </div>
<% end %>