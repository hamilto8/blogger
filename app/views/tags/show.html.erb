<div class="page-header">
  <div>
    <div style="margin-bottom: 0.5rem;">
      <%= link_to "&larr; All Topics".html_safe, tags_path, style: "color: var(--text-muted); font-size: 0.9rem; font-weight: 500;" %>
    </div>
    <h1 class="page-title">#<%= @tag.name %></h1>
    <p class="page-subtitle"><%= pluralize(@tag.articles.count, "perspective") %> indexed under this topic.</p>
  </div>
  <div>
    <%= link_to "Delete Topic", tag_path(@tag), method: :delete, data: { confirm: "Are you sure you want to remove the topic '#{@tag.name}'? The articles will remain published." }, class: "btn btn-danger btn-sm" %>
  </div>
</div>

<% if @tag.articles.empty? %>
  <div style="text-align: center; padding: 4rem; background: var(--bg-card); border-radius: var(--radius-lg); border: 1px solid var(--border-color);">
    <p style="color: var(--text-muted); font-style: italic;">No articles are currently tagged with #<%= @tag.name %>.</p>
  </div>
<% else %>
  <div class="articles-grid">
    <% @tag.articles.order(created_at: :desc).each do |article| %>
      <article class="article-card">
        <% if article.image_exists? %>
          <div class="article-image-wrapper">
            <%= link_to article_path(article) do %>
              <%= image_tag article.image_url, class: "article-image", alt: article.title %>
            <% end %>
          </div>
        <% else %>
          <div class="article-image-wrapper" style="background: linear-gradient(135deg, #f5f2eb 0%, #e8e4dc 100%); display: flex; align-items: center; justify-content: center;">
            <span style="font-family: var(--font-serif); color: var(--text-muted); font-size: 1.25rem; font-weight: 700;">Blogger.</span>
          </div>
        <% end %>

        <div class="article-card-content">
          <div class="article-meta">
            <span><%= article.created_at.strftime("%B %d, %Y") %></span>
            <span>&bull;</span>
            <span class="read-time"><%= article.reading_time %> min read</span>
          </div>

          <h2 class="article-card-title">
            <%= link_to article.title, article_path(article) %>
          </h2>

          <p class="article-excerpt">
            <%= truncate(article.body, length: 140) %>
          </p>

          <div class="article-footer">
            <div style="display: flex; gap: 0.4rem; flex-wrap: wrap;">
              <% article.tags.first(3).each do |tag| %>
                <%= link_to tag.name, tag_path(tag), class: "tag-badge" %>
              <% end %>
            </div>
            <div>
              <%= link_to "Read &rarr;".html_safe, article_path(article), style: "font-weight: 600; font-size: 0.85rem;" %>
            </div>
          </div>
        </div>
      </article>
    <% end %>
  </div>
<% end %>